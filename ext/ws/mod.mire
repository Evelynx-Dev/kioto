module ws
extern fn pal_ws_connect: (host :str, port :i64, path :str) :i64 lib "c"
extern fn pal_ws_send_text: (fd :i64, data :str) lib "c"
extern fn pal_ws_recv: (fd :i64, max_bytes :i64) :str lib "c"
extern fn pal_ws_close: (fd :i64) lib "c"
extern fn pal_wss_connect: (host :str, port :i64, path :str) :i64 lib "c"
extern fn pal_wss_send_text: (fd :i64, data :str) lib "c"
extern fn pal_wss_recv: (fd :i64, max_bytes :i64) :str lib "c"
extern fn pal_wss_close: (fd :i64) lib "c"

pub fn connect: (url :&str) :i64 {
    set u1 = *url
    set host = extract_ws_host(u1)
    set u2 = *url
    set port = extract_ws_port(u2) :i64 mut
    set u3 = *url
    set use_tls = strings::startswith(u3 "wss://")
    if port < 1 {
        if use_tls { set port = 443 :i64 }
        if !use_tls { set port = 80 :i64 }
    }
    set u4 = *url
    set path = extract_ws_path(u4)

    set h = host
    set p = port
    set pt = path
    if use_tls { return pal_wss_connect(h, p, pt) }
    return pal_ws_connect(h, p, pt)
}

pub fn send_text: (fd :i64, message :&str) {
    set m = *message
    pal_ws_send_text(fd, m)
}

pub fn recv: (fd :i64, max_bytes :i64) :str {
    return pal_ws_recv(fd, max_bytes)
}

pub fn recv_all: (fd :i64) :str {
    return pal_ws_recv(fd, 65536 :i64)
}

pub fn close: (fd :i64) {
    pal_ws_close(fd)
}

fn extract_ws_host: (url :str) :str {
    set u = url :str mut
    set scheme = "://"
    set pos = strings::index_of(u scheme)
    if pos >= 0 { set u = strings::substr(u pos + 3 strings::len(u)) }
    set slash = strings::index_of(u "/") :i64 mut
    set colon = strings::index_of(u ":") :i64 mut
    if colon < 0 {
        if slash < 0 { return u }
        return strings::substr(u 0 slash)
    }
    if slash < 0 { return strings::substr(u 0 colon) }
    set end = colon :i64 mut
    if slash < colon { set end = slash }
    return strings::substr(u 0 end)
}

fn extract_ws_port: (url :str) :i64 {
    set u = url :str mut
    set scheme = "://"
    set pos = strings::index_of(u scheme)
    if pos >= 0 { set u = strings::substr(u pos + 3 strings::len(u)) }
    set colon = strings::index_of(u ":")
    if colon < 0 { return 0 :i64 }
    set after = strings::substr(u colon + 1 strings::len(u))
    set slash = strings::index_of(after "/") :i64 mut
    set port_str = after :str mut
    if slash >= 0 { set port_str = strings::substr(after 0 slash) }
    return strings::to_i64(port_str)
}

fn extract_ws_path: (url :str) :str {
    set u = url :str mut
    set scheme = "://"
    set pos = strings::index_of(u scheme)
    if pos >= 0 { set u = strings::substr(u pos + 3 strings::len(u)) }
    set slash = strings::index_of(u "/")
    if slash < 0 { return "/" }
    return strings::substr(u slash strings::len(u))
}
